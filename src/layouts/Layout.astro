---
import { ClientRouter } from 'astro:transitions';

import '../styles/reset.css';
import '../styles/fonts.css';
import '../styles/global.css';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
}

const { title } = Astro.props;
const GA_MEASUREMENT_ID = import.meta.env
    .PUBLIC_GOOGLE_ANALYTICS_MEASUREMENT_ID;
---

<!doctype html>
<html lang="en">
    <head>
        <!-- Google tag (gtag.js) -->
        <script
            is:inline
            type="text/partytown"
            src=`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`
        ></script>
        <script
            is:inline
            type="text/partytown"
            define:vars={{ GA_MEASUREMENT_ID }}
        >
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag('js', new Date());

            gtag('consent', 'default', { analytics_storage: 'granted' });

            gtag('config', GA_MEASUREMENT_ID, {
                send_page_view: true,
            });
        </script>
        <meta charset="UTF-8" />
        <meta name="description" content="Àlex Marlés — UX Engineer based in Barcelona." />
        <meta name="viewport" content="width=device-width" />
        <link rel="preload" href="/fonts/LibreFranklin-VariableFont_wght.ttf" as="font" type="font/ttf" crossorigin />
        <link rel="preload" href="/fonts/AndadaPro-VariableFont_wght.ttf" as="font" type="font/ttf" crossorigin />
        <link rel="icon" type="image/svg+xml" href="/logo.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <ClientRouter />
    </head>
    <body>
        <Header path={Astro.url.pathname} transition:persist />
        <slot />
        <Footer />

        <script is:inline>
            document.addEventListener('astro:after-swap', () => {
                window.gtag?.('event', 'page_view', {
                    page_location: location.href,
                    page_path: location.pathname,
                    page_title: document.title,
                });
            });
        </script>
    </body>
</html>
